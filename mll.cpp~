class mallaHermite : public malla{
private:
  std::vector<double> nodos;
  std::vector<double> pesos;

public:
  void construir(int N) override{

    nodos.resize(N);
    pesos.resize(N);

    const gsl_integration_fixed_type*T = gsl_integration_fixed_hermite;

    gsl_integration_fixed_workspace* w = gsl_integration_fixed_alloc(T, N, 0.0,1.0);

    for(int i=0; i<N; i++){
      double xi, wi;
      gsl_integration_fixed_point(w,i,&xi, &wi);
      nodos[i] = xi;
      pesos[i] = wi;
    }
    gsl_integration_fixed_free(w);
  }
  const std::vector<double>& getNodos()const override{return nodos;}
  const std::vector<double>& getPesos()const override{return pesos;}
};
//seleccion por factory
std::unique_ptr<malla> crearmalla(const std::string& tipo_malla){
  if (tipo_malla == "Legendre")
    return std::make_unique<mallaLegendre>();
  else if (tipo_malla =="Laguerre")
    return std::make_unique<mallaLaguerre>();
  else if (tipo_malla=="Hermite")
    return std::make_unique<mallaHermite>();
  else
    throw std::invalid_argument("No esta esa malla");
}

